# TW_RealEstate_ETL — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# ---------- Database ----------
REALPRICE_DB_HOST=localhost
REALPRICE_DB_PORT=5432
REALPRICE_DB_NAME=tw_realestate
REALPRICE_DB_USER=your_username
REALPRICE_DB_PASSWORD=

# ---------- Paths ----------
# Backup directory (e.g. Google Drive sync folder)
# Default: ./backups
# REALPRICE_BACKUP_DIR=/path/to/your/backup/folder

# Data directory (downloaded ZIPs and extracted CSVs)
# Default: ./data
# REALPRICE_DATA_DIR=/path/to/your/data/folder

# ---------- Backup ----------
# 0 = keep all backups (default), N = keep latest N
REALPRICE_BACKUP_KEEP_COUNT=0

# ---------- Download ----------
# Seconds between consecutive downloads to avoid rate limiting
REALPRICE_DOWNLOAD_DELAY=10

# ---------- Load ----------
# Batch size for upsert operations
REALPRICE_BATCH_SIZE=500
